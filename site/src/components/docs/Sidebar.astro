---
import { DOCS_NAV } from "../../lib/docs-nav";
import { url } from "../../lib/site";

interface Props {
  current: string;
}
const { current } = Astro.props;
---

<aside class="sidebar">
  <nav>
    <p class="sidebar-title">Documentation</p>
    <ul>
      {
        DOCS_NAV.map((d) => (
          <li>
            <a
              href={url(`/docs/${d.slug}`)}
              class={d.slug === current ? "active" : ""}
            >
              {d.label ?? d.title}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: var(--nav-h);
    align-self: start;
    height: calc(100vh - var(--nav-h));
    overflow-y: auto;
    padding: 28px 16px 28px 0;
  }
  .sidebar-title {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--fg-dim);
    margin: 0 0 12px 12px;
  }
  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  li {
    margin: 1px 0;
  }
  a {
    display: block;
    padding: 7px 12px;
    border-radius: var(--radius-sm);
    color: var(--fg-muted);
    font-size: 14.5px;
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: background 0.12s ease, color 0.12s ease;
  }
  a:hover {
    background: var(--panel);
    color: var(--fg);
    text-decoration: none;
  }
  a.active {
    background: rgba(51, 102, 255, 0.12);
    color: #fff;
    border-left-color: var(--accent);
    font-weight: 600;
  }

  /* On mobile the sidebar becomes a horizontal, scrollable strip of links
     pinned beneath the nav — so it takes minimal vertical space and the doc
     content starts immediately, instead of reserving a full viewport height. */
  @media (max-width: 860px) {
    .sidebar {
      position: sticky;
      top: var(--nav-h);
      z-index: 20;
      height: auto;
      margin: 0 -18px;
      padding: 0;
      background: rgba(20, 20, 31, 0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    .sidebar-title {
      display: none;
    }
    ul {
      display: flex;
      gap: 4px;
      overflow-x: auto;
      padding: 8px 18px;
      scrollbar-width: none;
    }
    ul::-webkit-scrollbar {
      display: none;
    }
    li {
      margin: 0;
      flex: none;
    }
    a {
      border-left: none;
      border-radius: 999px;
      padding: 6px 14px;
      white-space: nowrap;
      font-size: 14px;
    }
    a.active {
      border-left: none;
      background: rgba(51, 102, 255, 0.18);
    }
  }
</style>
