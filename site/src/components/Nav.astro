---
import { SITE, url } from "../lib/site";

const path = Astro.url.pathname.replace(/\/$/, "");
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const isDocs = path.startsWith(`${base}/docs`);
---

<header class="nav">
  <div class="nav-inner container">
    <a class="brand" href={url("/")}>
      <span class="brand-mark">yui</span>
    </a>

    <nav class="nav-links">
      <a href={url("/docs/getting-started")} class={isDocs ? "active" : ""}
        >Docs</a
      >
      <a href={url("/#examples")}>Examples</a>
      <a href={SITE.repo} target="_blank" rel="noopener" class="gh">
        <svg viewBox="0 0 16 16" width="18" height="18" aria-hidden="true">
          <path
            fill="currentColor"
            d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"
          ></path>
        </svg>
        <span class="gh-text">GitHub</span>
      </a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    height: var(--nav-h);
    background: rgba(20, 20, 31, 0.8);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .brand {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .brand-mark {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 22px;
    letter-spacing: -0.02em;
    color: #fff;
    background: linear-gradient(135deg, var(--accent-hover), var(--green-bright));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
  }
  .nav-links a {
    color: var(--fg-muted);
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.15s ease;
  }
  .nav-links a:hover,
  .nav-links a.active {
    color: var(--fg);
  }
  .gh {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  @media (max-width: 560px) {
    .gh-text {
      display: none;
    }
    .nav-links {
      gap: 20px;
    }
  }
</style>
