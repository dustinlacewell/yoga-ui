---
import Base from "./Base.astro";
import Sidebar from "../components/docs/Sidebar.astro";
import Pager from "../components/docs/Pager.astro";
import { docTitle } from "../lib/docs-nav";

interface Props {
  slug: string;
}
const { slug } = Astro.props;
const title = docTitle(slug);
---

<Base title={title} footer={false}>
  <div class="docs-shell container">
    <Sidebar current={slug} />
    <main class="docs-main">
      <article class="prose">
        <slot />
      </article>
      <Pager current={slug} />
    </main>
  </div>
</Base>

<style>
  .docs-shell {
    display: grid;
    grid-template-columns: 230px minmax(0, 1fr);
    gap: 40px;
    align-items: start;
  }
  .docs-main {
    padding: 36px 0 64px;
    min-width: 0;
  }
  @media (max-width: 860px) {
    .docs-shell {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .docs-main {
      padding-top: 16px;
    }
  }
</style>

<style is:global>
  /* Prose styling for rendered markdown docs. */
  .prose {
    font-size: 16px;
    line-height: 1.7;
    color: var(--fg);
    max-width: 760px;
  }
  .prose > :first-child {
    margin-top: 0;
  }
  .prose h1 {
    font-size: clamp(30px, 4vw, 38px);
    letter-spacing: -0.02em;
    margin: 0 0 8px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }
  .prose h2 {
    font-size: 25px;
    letter-spacing: -0.015em;
    margin: 44px 0 14px;
    padding-top: 4px;
  }
  .prose h3 {
    font-size: 19px;
    margin: 30px 0 10px;
  }
  .prose h4 {
    font-size: 16px;
    margin: 24px 0 8px;
    color: var(--fg);
  }
  .prose p {
    margin: 14px 0;
    color: var(--fg-muted);
  }
  .prose strong {
    color: var(--fg);
    font-weight: 650;
  }
  .prose a {
    color: var(--accent-hover);
    text-decoration: none;
    border-bottom: 1px solid rgba(68, 119, 255, 0.35);
  }
  .prose a:hover {
    border-bottom-color: var(--accent-hover);
  }
  .prose ul,
  .prose ol {
    margin: 14px 0;
    padding-left: 24px;
    color: var(--fg-muted);
  }
  .prose li {
    margin: 6px 0;
  }
  .prose li::marker {
    color: var(--fg-dim);
  }
  .prose pre {
    margin: 18px 0;
  }
  .prose blockquote {
    margin: 18px 0;
    padding: 4px 18px;
    border-left: 3px solid var(--accent);
    background: var(--panel);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    color: var(--fg-muted);
  }
  .prose blockquote p {
    margin: 10px 0;
  }

  /* Tables — common in the primitives/architecture docs. */
  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 20px 0;
    font-size: 14.5px;
    display: block;
    overflow-x: auto;
  }
  .prose th,
  .prose td {
    text-align: left;
    padding: 9px 14px;
    border: 1px solid var(--border);
  }
  .prose th {
    background: var(--panel);
    color: var(--fg);
    font-weight: 600;
  }
  .prose td {
    color: var(--fg-muted);
  }
  .prose tr:nth-child(even) td {
    background: rgba(255, 255, 255, 0.015);
  }
  .prose hr {
    margin: 36px 0;
    border-top: 1px solid var(--border);
  }
